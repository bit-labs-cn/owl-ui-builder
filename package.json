{
  "name": "flex-dev-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:asset": "vite --open /asset.html",
    "build": "rimraf dist && vite build",
    "build:staging": "rimraf dist && vite build --mode staging",
    "preview": "vite preview"
  },
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=22.0.0",
    "pnpm": ">=9"
  },
  "pnpm": {
    "allowedDeprecatedVersions": {
      "are-we-there-yet": "*",
      "sourcemap-codec": "*",
      "domexception": "*",
      "w3c-hr-time": "*",
      "inflight": "*",
      "npmlog": "*",
      "rimraf": "*",
      "stable": "*",
      "gauge": "*",
      "abab": "*",
      "glob": "*"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "9"
      }
    }
  },
  "devDependencies": {
    "@bit-labs.cn/owl-ui": "workspace:*",

    "@bit-labs.cn/owl-admin-ui": "workspace:*",

    "@bit-labs.cn/owl-cms-ui": "workspace:*",

    "@bit-labs.cn/owl-workorder-ui": "workspace:*",

    "@bit-labs.cn/lift-vision-ui": "workspace:*",
    
    "@bit-labs.cn/owl-portal-ui": "workspace:*",

    "@bit-labs.cn/asset-manage-ui": "workspace:*",

    "@bit-labs.cn/owl-inspection-ui": "workspace:*",

    "@intlify/unplugin-vue-i18n": "^6.0.1",
    "@types/node": "^20.17.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-import": "^16.1.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.16",
    "typescript": "5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-remove-console": "^2.2.0",
    "vite-plugin-router-warn": "^1.0.0",
    "vite-svg-loader": "^5.1.0",
    "vue": "^3.5.13"
  }
}
